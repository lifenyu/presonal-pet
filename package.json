{
  "name": "pet",
  "version": "1.0.0",
  "description": "Electron + React + TypeScript + SQLite 桌面宠物应用",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:electron": "tsc -p tsconfig.main.json && wait-on http://localhost:9000 && env -u ELECTRON_RUN_AS_NODE electron .",
    "dev:renderer": "webpack serve --config webpack.config.js --mode development",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --config webpack.config.js --mode production",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/sql.js": "^1.4.11",
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "electron": "^24.8.8",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "wait-on": "^9.0.10",
    "webpack": "^5.100.0",
    "webpack-cli": "^7.1.0",
    "webpack-dev-server": "^5.2.2"
  }
}
